# XcodeGen output — regenerated from project.yml
*.xcodeproj/

# Local, machine-specific signing identity
Signing.local.xcconfig

# Build artifacts
build/
DerivedData/
.swiftpm/
*.xcresult

# Screenshots scratch (visual-verification output)
screenshots/

# macOS
.DS_Store

# NOTE: the harness's OWN local-scratch ignores (loop scratch + status board, atomic-write temps, the
# ideas->tasks pipeline dirs, scope-gap dismissals) are maintained automatically as a marker-delimited
# "# >>> implementation-harness managed >>>" block, appended by .harness/scripts/ensure-gitignore.sh
# (run on create and on every upgrade). Don't add those by hand here — put your own entries anywhere
# OUTSIDE that block and they'll be left untouched.

# >>> implementation-harness managed (auto-maintained — do not edit inside) >>>
# Transient loop scratch (last-iteration verdict) + the generated status board.
.harness/worklog/.result
.harness/worklog/.claude-out*
.harness/worklog/.claude-prompt*
.harness/worklog/.failures.buf
.harness/worklog/.current.json
.harness/worklog/STATUS.md
.harness/worklog/*.log
.harness/worklog/*.audit.md
# atomic-write temps (TASKS.json + the owner-overlay files never keep a crashed-mid-write file)
.harness/tracking/*.tmp
.harness/tracking/*.tmp.*
# ideas->tasks pipeline — ephemeral per-sweep scratch (the .gitkeep keeps each dir in a fresh clone)
.harness/.pending-tasks/*
!.harness/.pending-tasks/.gitkeep
.harness/.pending-questions/*
!.harness/.pending-questions/.gitkeep
# scope-gap dismissals — check-task-scope.sh's per-task "already reviewed" record (fix-scope-gaps)
.harness/.scope-gap-ignores/*
!.harness/.scope-gap-ignores/.gitkeep
# harness-fetched tool binaries (e.g. actionlint — ensure-actionlint.sh) — machine-specific, never committed
.harness/.bin/
# <<< implementation-harness managed <<<
